<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Разрешаем пользовательские сертификаты для сервера Conduit -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">xemooll.ru</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
